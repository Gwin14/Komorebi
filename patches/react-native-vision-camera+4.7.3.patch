diff --git a/node_modules/react-native-vision-camera/ios/Core/CameraSession+Photo.swift b/node_modules/react-native-vision-camera/ios/Core/CameraSession+Photo.swift
index 12f5c07..1163a5d 100644
--- a/node_modules/react-native-vision-camera/ios/Core/CameraSession+Photo.swift
+++ b/node_modules/react-native-vision-camera/ios/Core/CameraSession+Photo.swift
@@ -39,7 +39,24 @@ extension CameraSession {
       VisionLogger.log(level: .info, message: "Capturing photo...")
 
       // Create photo settings
-      let photoSettings = AVCapturePhotoSettings()
+      let photoSettings: AVCapturePhotoSettings
+      if options.rawMode != "off" {
+        let availableFormats = photoOutput.availableRawPhotoPixelFormatTypes
+        guard let rawPixelFormat = self.getRawPixelFormat(for: options.rawMode, availableFormats: availableFormats) else {
+          let activeFormat = videoDeviceInput.device.activeFormat
+          let dimensions = CMVideoFormatDescriptionGetDimensions(activeFormat.formatDescription)
+          promise.reject(error: .capture(.unknown(message: "\(options.rawMode) capture is not supported by this camera configuration. rawFormats=\(availableFormats), activeFormat=\(dimensions.width)x\(dimensions.height), device=\(videoDeviceInput.device.localizedName)")))
+          return
+        }
+
+        let processedFormat = [AVVideoCodecKey: AVVideoCodecType.jpeg]
+        photoSettings = AVCapturePhotoSettings(rawPixelFormatType: rawPixelFormat,
+                                               rawFileType: .dng,
+                                               processedFormat: processedFormat,
+                                               processedFileType: AVFileType("public.jpeg"))
+      } else {
+        photoSettings = AVCapturePhotoSettings()
+      }
 
       // set photo resolution
       if #available(iOS 16.0, *) {
@@ -91,4 +108,20 @@ extension CameraSession {
       photoOutput.setPreparedPhotoSettingsArray([photoSettings], completionHandler: nil)
     }
   }
+
+  private func getRawPixelFormat(for rawMode: String, availableFormats: [OSType]) -> OSType? {
+    guard !availableFormats.isEmpty else {
+      return nil
+    }
+
+    if #available(iOS 14.3, *) {
+      if rawMode == "proRaw" {
+        return availableFormats.first(where: { AVCapturePhotoOutput.isAppleProRAWPixelFormat($0) })
+      }
+
+      return availableFormats.first(where: { AVCapturePhotoOutput.isBayerRAWPixelFormat($0) })
+    }
+
+    return rawMode == "raw" ? availableFormats.first : nil
+  }
 }
