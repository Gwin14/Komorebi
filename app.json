{
  "expo": {
    "name": "Komorebi",
    "platforms": ["ios", "android"],
    "slug": "Komorebi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.jpeg",
    "scheme": "camera",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "br.dev.fabiosantos.komorebi",
      "supportsTablet": true,
      "infoPlist": {
        "LSRequiresIPhoneOS": true,
        "UIRequiredDeviceCapabilities": ["camera"],
        "NSCameraUsageDescription": "Precisamos da câmera para tirar fotos.",
        "NSMicrophoneUsageDescription": "Precisamos do microfone para gravar vídeos."
      }
    },
    "android": {
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.jpeg",
        "backgroundImage": "./assets/images/logo.jpeg",
        "monochromeImage": "./assets/images/logo.jpeg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "br.dev.fabiosantos.komorebi"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icone.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      ["react-native-vision-camera"],
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir que o Komorebi acesse suas fotos.",
          "savePhotosPermission": "Permitir que o Komorebi salve fotos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permitir que o app acesse sua localização para adicionar GPS às fotos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ],
      "expo-web-browser",
      "./plugins/withIosDeploymentTarget",
      "./plugins/withUiSceneManifest"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f037b9c6-aec0-4cfb-bcac-c33532852726"
      }
    }
  }
}
